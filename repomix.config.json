{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml"
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "node_modules",
      "dist",
      ".vite",
      "public/master_locations.json",
      "output/*",
      "artifacts/*",
      "scripts/*.json",
      "*.db*",
      "repomix-output.xml"
    ]
  }
}
